# ================================================
# ROUTESGO - Configuração de Fatores de Correção
# ================================================

# Fator de correção de tráfego padrão
# O OSRM calcula tempo teórico sem considerar trânsito real
# Este fator aproxima o cálculo da realidade
#
# Calibrado com rotas reais brasileiras:
# Exemplo: 47 min (OSRM) × 1.65 = 77 min (próximo Google Maps)
#
# Valores sugeridos:
# - 1.65 = +65% (áreas urbanas brasileiras) ⭐ RECOMENDADO
# - 1.45 = +45% (áreas suburbanas)
# - 1.80 = +80% (metrópoles congestionadas - SP, RJ)
# - 1.15 = +15% (rodovias)
# - 2.00 = +100% (horário de pico)
ROUTESGO_TRAFFIC_FACTOR=1.65

# Habilitar logs de debug do RotasGo
# true = registra todas as chamadas OSRM no laravel.log
# false = desabilita logs (produção)
ROUTESGO_DEBUG=false

# URL do servidor OSRM (opcional)
# Padrão: https://router.project-osrm.org
# OSRM_BASE_URL=https://router.project-osrm.org

# Perfil de roteamento (opcional)
# Padrão: driving
# Opções: driving, walking, cycling
# OSRM_PROFILE=driving

# Timeout para requisições OSRM em segundos (opcional)
# Padrão: 10
# OSRM_TIMEOUT=10
